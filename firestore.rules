rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      // Hardcoded admin email for solo app developer
      return isSignedIn() && request.auth.token.email == 'hoya100304@gmail.com' && request.auth.token.email_verified == true; 
    }

    // Validation
    function isValidNotice(data) {
      let reqKeys = ['title', 'content', 'date'];
      return data.keys().hasAll(reqKeys) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.date is string && data.date.size() <= 100 &&
             (data.keys().hasAny(['createdAt']) ? (data.createdAt is string && data.createdAt.size() <= 100) : true) &&
             (data.keys().hasAny(['fileUrl']) ? (data.fileUrl is string && data.fileUrl.size() <= 2000) : true) &&
             (data.keys().hasAny(['fileName']) ? (data.fileName is string && data.fileName.size() <= 500) : true) &&
             (data.keys().hasAny(['files']) ? (data.files is list && data.files.size() <= 10) : true) &&
             (data.keys().hasAny(['isArchived']) ? (data.isArchived is bool) : true) &&
             (data.keys().hasAny(['archivedAt']) ? (data.archivedAt is string && data.archivedAt.size() <= 100) : true) &&
             (data.keys().hasAny(['validUntil']) ? (data.validUntil is string && data.validUntil.size() <= 100) : true) &&
             (data.keys().hasAny(['link']) ? (data.link is string && data.link.size() <= 2000) : true);
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 100 &&
             (data.keys().hasAny(['description']) ? (data.description is string && data.description.size() <= 1000) : true) &&
             (data.keys().hasAny(['endDate']) ? (data.endDate is string && data.endDate.size() <= 100) : true) &&
             (data.keys().hasAny(['createdAt']) ? (data.createdAt is string && data.createdAt.size() <= 100) : true) &&
             (data.keys().hasAny(['color']) ? (data.color is string && data.color.size() <= 50) : true) &&
             (data.keys().hasAny(['isHoliday']) ? (data.isHoliday is bool) : true) &&
             (data.keys().hasAny(['isArchived']) ? (data.isArchived is bool) : true) &&
             (data.keys().hasAny(['archivedAt']) ? (data.archivedAt is string && data.archivedAt.size() <= 100) : true);
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['title']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             (data.keys().hasAny(['description']) ? (data.description is string && data.description.size() <= 10000) : true) &&
             (data.keys().hasAny(['createdAt']) ? (data.createdAt is string && data.createdAt.size() <= 100) : true) &&
             (data.keys().hasAny(['fileUrl']) ? (data.fileUrl is string && data.fileUrl.size() <= 2000) : true) &&
             (data.keys().hasAny(['fileName']) ? (data.fileName is string && data.fileName.size() <= 500) : true) &&
             (data.keys().hasAny(['files']) ? (data.files is list && data.files.size() <= 10) : true) &&
             (data.keys().hasAny(['isArchived']) ? (data.isArchived is bool) : true) &&
             (data.keys().hasAny(['archivedAt']) ? (data.archivedAt is string && data.archivedAt.size() <= 100) : true) &&
             (data.keys().hasAny(['link']) ? (data.link is string && data.link.size() <= 2000) : true);
    }

    function isValidSiteInfo(data) {
      return data.keys().hasAll(['content', 'updatedAt']) &&
             data.keys().size() == 2 &&
             data.content is string && data.content.size() <= 10000 &&
             data.updatedAt is string && data.updatedAt.size() <= 100;
    }

    // Timetable Memos Validation
    function isValidTimetableMemo(data) {
      return data.keys().hasAll(['grade', 'department', 'classNumber', 'weekStart', 'dayOfWeek', 'period', 'memo']) &&
             (data.keys().size() == 7 || (data.keys().size() == 8 && data.keys().hasAll(['createdAt']))) &&
             data.grade is int && data.grade >= 1 && data.grade <= 3 &&
             data.department is string && data.department.size() <= 100 &&
             data.classNumber is int && data.classNumber >= 1 && data.classNumber <= 2 &&
             data.weekStart is string && data.weekStart.size() <= 20 &&
             data.dayOfWeek is int && data.dayOfWeek >= 0 && data.dayOfWeek <= 4 &&
             data.period is int && data.period >= 1 && data.period <= 7 &&
             data.memo is string && data.memo.size() <= 500 &&
             (data.keys().hasAny(['createdAt']) ? (data.createdAt is string && data.createdAt.size() <= 100) : true);
    }

    // Timetable Templates Validation
    function isValidTimetableTemplate(data) {
      return data.keys().hasAll(['grade', 'department', 'classNumber', 'rawTimetable']) &&
             data.grade is int &&
             data.department is string &&
             data.classNumber is int &&
             data.rawTimetable is string;
    }

    // Notice Collection
    match /notices/{noticeId} {
      allow read: if true; // Public access to notices
      allow create: if isAdmin() && isValidId(noticeId) && isValidNotice(incoming());
      allow update: if isAdmin() && isValidId(noticeId) && isValidNotice(incoming());
      allow delete: if isAdmin() && isValidId(noticeId);
    }

    // Academic Events Collection
    match /events/{eventId} {
      allow read: if true; // Public access to events
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow delete: if isAdmin() && isValidId(eventId);
    }

    // Documents Collection
    match /documents/{docId} {
      allow read: if true; // Public access to documents
      allow create: if isAdmin() && isValidId(docId) && isValidDocument(incoming());
      allow update: if isAdmin() && isValidId(docId) && isValidDocument(incoming());
      allow delete: if isAdmin() && isValidId(docId);
    }

    // Site Info Collection
    match /siteInfo/{infoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(infoId) && isValidSiteInfo(incoming());
      allow update: if isAdmin() && isValidId(infoId) && isValidSiteInfo(incoming());
      allow delete: if isAdmin() && isValidId(infoId);
    }

    // Timetable Memos Collection
    match /timetable_memos/{memoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(memoId) && isValidTimetableMemo(incoming());
      allow update: if isAdmin() && isValidId(memoId) && isValidTimetableMemo(incoming());
      allow delete: if isAdmin() && isValidId(memoId);
    }

    // Timetable Templates Collection
    match /timetable_templates/{templateId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(templateId) && isValidTimetableTemplate(incoming());
      allow update: if isAdmin() && isValidId(templateId) && isValidTimetableTemplate(incoming());
      allow delete: if isAdmin() && isValidId(templateId);
    }
  }
}
