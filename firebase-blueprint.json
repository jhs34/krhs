{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "A school notice or announcement.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the notice." },
        "content": { "type": "string", "description": "Details of the notice." },
        "date": { "type": "string", "format": "date-time", "description": "Notice date (ISO string)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "content", "date", "createdAt"]
    },
    "AcademicEvent": {
      "title": "AcademicEvent",
      "description": "An event in the academic calendar.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "color": { "type": "string" },
        "isHoliday": { "type": "boolean" }
      },
      "required": ["title", "description", "date", "createdAt"]
    },
    "SiteInfo": {
      "title": "SiteInfo",
      "description": "Global site information like announcements, updates, contact.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "updatedAt"]
    },
    "TimetableMemo": {
      "title": "TimetableMemo",
      "description": "Customizable weekly period memos / performance evaluation reminders.",
      "type": "object",
      "properties": {
        "grade": { "type": "integer" },
        "department": { "type": "string" },
        "classNumber": { "type": "integer" },
        "weekStart": { "type": "string" },
        "dayOfWeek": { "type": "integer" },
        "period": { "type": "integer" },
        "memo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["grade", "department", "classNumber", "weekStart", "dayOfWeek", "period", "memo"]
    },
    "TimetableTemplate": {
      "title": "TimetableTemplate",
      "description": "Customizable default repeating class timetable template.",
      "type": "object",
      "properties": {
        "grade": { "type": "integer" },
        "department": { "type": "string" },
        "classNumber": { "type": "integer" },
        "rawTimetable": { "type": "string" }
      },
      "required": ["grade", "department", "classNumber", "rawTimetable"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": {
      "schema": { "$ref": "#/entities/Notice" },
      "description": "Collection of school notices."
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/AcademicEvent" },
      "description": "Collection of academic calendar events."
    },
    "/siteInfo/{infoId}": {
      "schema": { "$ref": "#/entities/SiteInfo" },
      "description": "Global information snippets."
    },
    "/timetable_memos/{memoId}": {
      "schema": { "$ref": "#/entities/TimetableMemo" },
      "description": "Collection of weekly class period memo overrides."
    },
    "/timetable_templates/{templateId}": {
      "schema": { "$ref": "#/entities/TimetableTemplate" },
      "description": "Collection of customizable default repeating class timetable templates."
    }
  }
}
